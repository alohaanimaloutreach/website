---
/*
  Logo is auto-discovered from /src/assets/logos/
  Drop in a file named "logo" with any extension (.png, .svg, .jpg, .webp)
  and it will appear automatically.
*/
const logoFiles = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/logos/logo-black.{png,svg,jpg,jpeg,webp}',
  { eager: true }
);
const logoEntry = Object.values(logoFiles)[0];
const logoSrc = logoEntry?.default.src;

const whiteLogoFiles = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/logos/logo-white.{png,svg,jpg,jpeg,webp}',
  { eager: true }
);
const whiteLogoEntry = Object.values(whiteLogoFiles)[0];
const whiteLogoSrc = whiteLogoEntry?.default.src;

const navLinks = [
  { href: '/our-mission', label: 'Our Mission' },
  { href: '/success-stories', label: 'Success Stories' },
  { href: '/get-involved', label: 'Get Involved' },
  { href: 'https://shop.alohaanimaloutreach.org', label: 'Shop' },
];

// Announcement bar — set to null or empty string to hide
const announcement = {
  text: 'Oʻahu Flood Response: Read about our emergency relief efforts',
  link: '/blog/oahu-flood-emergency-response-march-2026',
};

const currentPath = Astro.url.pathname;

// Pages with dark hero sections get a transparent header
const darkHeroPages = ['/', '/our-mission', '/success-stories', '/get-involved', '/donate', '/blog', '/partners', '/foster'];
const hasDarkHero = darkHeroPages.includes(currentPath) || darkHeroPages.includes(currentPath.replace(/\/$/, '')) || currentPath.startsWith('/blog/');
---

{announcement?.text && (
  <div id="announcement-bar" class="fixed top-0 w-full z-[60] bg-accent text-anchor text-center text-xs sm:text-sm font-medium py-3.5 sm:py-2 px-8 sm:px-4">
    {announcement.link ? (
      <a href={announcement.link} class="hover:underline">
        {announcement.text} &rarr;
      </a>
    ) : (
      <span>{announcement.text}</span>
    )}
    <button id="announcement-close" class="absolute right-3 top-1/2 -translate-y-1/2 text-anchor/60 hover:text-anchor transition" aria-label="Dismiss announcement">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
)}

<header id="site-header" class:list={[
  'fixed w-full z-50 transition-all duration-300',
  announcement?.text ? '' : 'top-0',
  hasDarkHero ? 'bg-transparent' : 'bg-bg shadow-md'
]} data-dark-hero={hasDarkHero ? 'true' : 'false'} data-has-announcement={announcement?.text ? 'true' : 'false'}>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between py-4 md:py-8">
    <!-- Logo -->
    <a href="/" class="flex-shrink-0">
      {hasDarkHero && whiteLogoSrc ? (
        <>
          <img src={whiteLogoSrc} alt="Aloha Animal Outreach" class="h-20 w-auto header-logo-white transition-opacity duration-300" />
          <img src={logoSrc} alt="Aloha Animal Outreach" class="h-20 w-auto header-logo-dark transition-opacity duration-300 hidden" />
        </>
      ) : logoSrc ? (
        <img src={logoSrc} alt="Aloha Animal Outreach" class="h-20 w-auto" />
      ) : null}
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'nav-link text-sm font-medium transition-colors header-nav-link relative py-1',
            currentPath === link.href ? 'nav-link-active' : '',
            hasDarkHero
              ? (currentPath === link.href ? 'text-white' : 'text-white/80 hover:text-white')
              : (currentPath === link.href ? 'text-primary' : 'text-anchor hover:text-primary')
          ]}
          {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Donate Button + Mobile Toggle -->
    <div class="flex items-center gap-4">
      <a
        href="/donate"
        class="bg-primary text-white font-bold text-sm px-6 py-2.5 rounded-full shadow-md hover:shadow-lg hover:scale-105 active:scale-95 transition-all duration-200"
      >
        Donate
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class:list={[
          'md:hidden transition-colors',
          hasDarkHero ? 'text-white' : 'text-anchor'
        ]}
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-anchor border-t border-white/10 pb-4">
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={[
          'block px-6 py-3 text-sm font-medium transition-colors',
          currentPath === link.href
            ? 'text-accent'
            : 'text-white hover:text-accent'
        ]}
        {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<!-- Spacer for pages without dark hero (header won't overlay content) -->
{!hasDarkHero && <div id="header-spacer"></div>}

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });

  // Position header directly below announcement bar
  const announcementBar = document.getElementById('announcement-bar');
  const announcementClose = document.getElementById('announcement-close');
  const headerSpacer = document.getElementById('header-spacer');
  const siteHeader = document.getElementById('site-header');

  function positionHeader() {
    if (announcementBar && siteHeader) {
      const barHeight = announcementBar.offsetHeight;
      siteHeader.style.top = barHeight + 'px';
    }
    if (headerSpacer && siteHeader) {
      const totalHeight = (announcementBar ? announcementBar.offsetHeight : 0) + siteHeader.offsetHeight;
      headerSpacer.style.height = totalHeight + 'px';
    }
  }

  positionHeader();
  window.addEventListener('resize', positionHeader);

  announcementClose?.addEventListener('click', () => {
    announcementBar?.remove();
    if (siteHeader) {
      siteHeader.style.top = '0px';
    }
    if (headerSpacer && siteHeader) {
      headerSpacer.style.height = siteHeader.offsetHeight + 'px';
    }
  });

  // Scroll-based header transition for pages with dark heroes
  const header = document.getElementById('site-header');
  const hasDarkHero = header?.dataset.darkHero === 'true';

  if (hasDarkHero && header) {
    const whiteLogo = header.querySelector('.header-logo-white') as HTMLElement;
    const darkLogo = header.querySelector('.header-logo-dark') as HTMLElement;
    const navLinks = header.querySelectorAll('.header-nav-link');
    const hamburger = document.getElementById('mobile-menu-btn');

    function updateHeader() {
      const scrolled = window.scrollY > 50;

      if (scrolled) {
        header.classList.add('bg-bg', 'shadow-md');
        header.classList.remove('bg-transparent');
        if (whiteLogo) { whiteLogo.classList.add('hidden'); }
        if (darkLogo) { darkLogo.classList.remove('hidden'); }
        navLinks.forEach(link => {
          link.classList.remove('text-white', 'text-white/80', 'hover:text-white');
          if (link.getAttribute('href') === window.location.pathname) {
            link.classList.add('text-primary');
          } else {
            link.classList.add('text-anchor', 'hover:text-primary');
          }
        });
        if (hamburger) {
          hamburger.classList.remove('text-white');
          hamburger.classList.add('text-anchor');
        }
      } else {
        header.classList.remove('bg-bg', 'shadow-md');
        header.classList.add('bg-transparent');
        if (whiteLogo) { whiteLogo.classList.remove('hidden'); }
        if (darkLogo) { darkLogo.classList.add('hidden'); }
        navLinks.forEach(link => {
          link.classList.remove('text-anchor', 'hover:text-primary', 'text-primary');
          if (link.getAttribute('href') === window.location.pathname) {
            link.classList.add('text-white');
          } else {
            link.classList.add('text-white/80', 'hover:text-white');
          }
        });
        if (hamburger) {
          hamburger.classList.add('text-white');
          hamburger.classList.remove('text-anchor');
        }
      }
    }

    window.addEventListener('scroll', updateHeader, { passive: true });
    updateHeader();
  }
</script>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: currentColor;
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link-active::after {
    width: 100%;
  }
</style>
