---
import ImagePlaceholder from './ImagePlaceholder.astro';

interface Props {
  name: string;
  imageSrc: string;
  detail?: string;
}

const { name, imageSrc, detail } = Astro.props;
---

<div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow group">
  <ImagePlaceholder src={imageSrc} alt={name} aspectRatio="1/1" class="group-hover:scale-[1.02] transition-transform duration-300" />
  <div class="p-5 text-center">
    <h3 class="font-display text-lg font-semibold">{name}</h3>
    {detail && <p class="text-text-muted text-sm mt-1">{detail}</p>}
    <a href="#foster-inquiry" class="mt-3 text-primary text-sm font-semibold hover:underline">
      Inquire About {name}
    </a>
  </div>
</div>
