---

<section class="bg-anchor py-16">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-3">Stay in the Loop</h2>
    <p class="text-white/80 mb-8">Get monthly updates with real stories from the field, dogs who need help, and ways to make a difference from anywhere.</p>
    <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto">
      <input
        type="text"
        name="name"
        placeholder="First name"
        required
        class="flex-1 px-4 py-3 rounded-lg text-anchor bg-white placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-accent"
      />
      <input
        type="email"
        name="email"
        placeholder="Email address"
        required
        class="flex-1 px-4 py-3 rounded-lg text-anchor bg-white placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-accent"
      />
      <button
        type="submit"
        class="bg-accent text-anchor font-bold px-6 py-3 rounded-lg hover:brightness-110 transition"
      >
        Subscribe
      </button>
    </form>
    <p id="newsletter-msg" class="mt-4 text-white text-sm hidden"></p>
  </div>
</section>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const msg = document.getElementById('newsletter-msg');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    try {
      const res = await fetch('/api/newsletter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: data.get('name'),
          email: data.get('email'),
        }),
      });
      const json = await res.json();
      if (msg) {
        msg.classList.remove('hidden');
        msg.textContent = json.success
          ? 'Welcome to the ohana! Check your inbox.'
          : 'Something went wrong. Please try again.';
      }
      if (json.success) form.reset();
    } catch {
      if (msg) {
        msg.classList.remove('hidden');
        msg.textContent = 'Something went wrong. Please try again.';
      }
    }
  });
</script>
