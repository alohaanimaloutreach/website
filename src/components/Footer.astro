---
/*
  Footer logo is auto-discovered from /src/assets/logos/
  Drop in a file named "logo-white" with any extension (.png, .svg, .jpg, .webp)
  for the dark background version. Falls back to the regular "logo" file if no white version exists.
*/
const logoFiles = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/logos/logo-white.{png,svg,jpg,jpeg,webp}',
  { eager: true }
);
const logoEntry = Object.values(logoFiles)[0];
const footerLogoSrc = logoEntry?.default.src;

const navLinks = [
  { href: '/our-mission', label: 'Our Mission' },
  { href: '/success-stories', label: 'Success Stories' },
  { href: '/get-involved', label: 'Get Involved' },
  { href: '/donate', label: 'Donate' },
  { href: '/shop', label: 'Shop' },
];
---

<footer class="bg-anchor text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand — drop logo-white.png/.svg into /src/assets/logos/ -->
      <div>
        {footerLogoSrc ? (
          <img src={footerLogoSrc} alt="Aloha Animal Outreach" class="h-16 w-auto mb-4" />
        ) : (
          <span class="text-white font-display font-bold text-lg block mb-4">Aloha Animal Outreach</span>
        )}
        <p class="text-white/70 text-sm leading-relaxed max-w-xs">
          Providing food, veterinary care, and hope to pets in unhoused communities across Oʻahu.
        </p>
      </div>

      <!-- Nav Links -->
      <div>
        <h4 class="font-display text-lg font-semibold mb-4">Explore</h4>
        <nav class="flex flex-col gap-2">
          {navLinks.map(link => (
            <a href={link.href} class="text-white/70 text-sm hover:text-primary transition-colors"
              {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Social & Contact -->
      <div>
        <h4 class="font-display text-lg font-semibold mb-4">Connect</h4>
        <div class="flex gap-4 mb-6">
          <!-- Instagram -->
          <a href="https://www.instagram.com/alohaanimaloutreach/" aria-label="Instagram" class="text-white/70 hover:text-primary transition-colors" target="_blank" rel="noopener noreferrer">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <!-- Facebook -->
          <a href="https://www.facebook.com/AlohaAnimalOutreach/" aria-label="Facebook" class="text-white/70 hover:text-primary transition-colors" target="_blank" rel="noopener noreferrer">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385h-3.047v-3.47h3.047v-2.642c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953h-1.514c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385c5.738-.9 10.126-5.864 10.126-11.854z"/>
            </svg>
          </a>
          <!-- TikTok -->
          <a href="https://www.tiktok.com/@alohaanimaloutreach" aria-label="TikTok" class="text-white/70 hover:text-primary transition-colors" target="_blank" rel="noopener noreferrer">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.88a8.18 8.18 0 004.76 1.52V6.97a4.85 4.85 0 01-1-.28z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/10 text-center text-white/50 text-xs">
      <p>© 2026 Aloha Animal Outreach · 501(c)(3) Nonprofit · EIN 87-1327369</p>
      <p class="mt-2"><a href="https://shauna.digital" class="hover:text-accent transition" target="_blank" rel="noopener noreferrer">Built with <span class="heartbeat">♥</span></a></p>
    </div>
  </div>
</footer>

<style>
  .heartbeat {
    display: inline-block;
    color: #e05a6b;
    animation: heartbeat 1.4s ease infinite;
    transform-origin: center;
  }

  @keyframes heartbeat {
    0%   { transform: scale(1); }
    14%  { transform: scale(1.25); }
    28%  { transform: scale(1); }
    42%  { transform: scale(1.15); }
    56%  { transform: scale(1); }
    100% { transform: scale(1); }
  }
</style>
