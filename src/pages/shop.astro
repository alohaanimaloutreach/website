---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Shop | Aloha Animal Outreach" description="Shop to support the mission. Every purchase helps fund our outreach to pets in need.">

  <!-- Coming Soon -->
  <section class="py-24 md:py-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-6xl mb-6">🐾</div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-anchor mb-6">Coming Soon!</h2>
      <p class="text-text-muted text-lg leading-relaxed mb-10">
        We're working on a merch store where every purchase directly supports our mission. Tees, hoodies, tote bags, and more — all coming soon!
      </p>
      <p class="text-text-muted text-sm mb-10">
        Want to support us right now? You can make a direct donation below.
      </p>
      <a href="/donate" class="bg-accent text-anchor font-bold px-10 py-4 rounded-full text-lg hover:brightness-110 transition inline-block">
        Donate Now
      </a>
    </div>
  </section>

</Layout>
