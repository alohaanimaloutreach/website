---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import FosterDogCard from '../components/FosterDogCard.astro';
import fs from 'node:fs';
import path from 'node:path';

// Auto-discover foster dogs from /public/images/foster-dogs/
const fosterDir = path.join(process.cwd(), 'public/images/foster-dogs');
let fosterDogs: { name: string; imageSrc: string; detail?: string }[] = [];

if (fs.existsSync(fosterDir)) {
  const files = fs.readdirSync(fosterDir)
    .filter((f: string) => f.endsWith('.webp'))
    .sort((a: string, b: string) => a.localeCompare(b));

  fosterDogs = files.map((f: string) => {
    const base = f.replace('.webp', '');
    const withoutPrefix = base.replace(/^foster-/, '');
    const underscoreIdx = withoutPrefix.indexOf('_');
    const rawName = underscoreIdx > -1 ? withoutPrefix.slice(0, underscoreIdx) : withoutPrefix;
    const rawDetail = underscoreIdx > -1 ? withoutPrefix.slice(underscoreIdx + 1) : undefined;
    const name = rawName.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
    const detail = rawDetail
      ?.replace(/-/g, ' ')
      .replace(/(\d+)\s*(yr|mo|lbs)/g, '$1 $2')
      .replace(/^(\S)/, (_: string, c: string) => c.toUpperCase());
    return { name, imageSrc: `/images/foster-dogs/${f}`, detail };
  });
}
