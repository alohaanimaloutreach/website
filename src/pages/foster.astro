              <input type="email" id="foster-email" name="email" required
                class="w-full px-4 py-3 rounded-lg border border-dark/15 text-anchor bg-white placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="foster-phone" class="block text-sm font-semibold mb-1">Phone <span class="text-text-muted font-normal">(optional)</span></label>
              <input type="tel" id="foster-phone" name="phone"
                class="w-full px-4 py-3 rounded-lg border border-dark/15 text-anchor bg-white placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary" />
            </div>
            <div>
              <label for="foster-location" class="block text-sm font-semibold mb-1">Location / Area</label>
              <input type="text" id="foster-location" name="location" placeholder="e.g. Kailua, Honolulu" required
                class="w-full px-4 py-3 rounded-lg border border-dark/15 text-anchor bg-white placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary" />
            </div>
          </div>

          <div>
            <label for="foster-living" class="block text-sm font-semibold mb-1">Living situation</label>
            <select id="foster-living" name="living-situation" required
              class="w-full px-4 py-3 rounded-lg border border-dark/15 text-anchor bg-white focus:outline-none focus:ring-2 focus:ring-primary">
              <option value="" disabled selected>Select one</option>
              <option value="house-yard">House with yard</option>
              <option value="house-no-yard">House without yard</option>
              <option value="apartment">Apartment / Condo</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="foster-pets" class="block text-sm font-semibold mb-1">Do you have other pets?</label>
            <input type="text" id="foster-pets" name="other-pets" placeholder="e.g. One cat, no dogs"
              class="w-full px-4 py-3 rounded-lg border border-dark/15 text-anchor bg-white placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary" />
          </div>

          <div>
            <label for="foster-message" class="block text-sm font-semibold mb-1">Anything else you'd like us to know?</label>
            <textarea id="foster-message" name="message" rows="3"
              class="w-full px-4 py-3 rounded-lg border border-dark/15 text-anchor bg-white placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary resize-y"></textarea>
          </div>

          <button type="submit"
            class="bg-primary text-white font-bold px-8 py-3 rounded-full hover:brightness-110 transition">
            Submit Foster Inquiry
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- CTA Strip -->
  <section class="bg-primary py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-6">Not Ready to Foster? You Can Still Help.</h2>
      <p class="text-white/90 text-lg mb-10">Every contribution makes a difference — whether it's a donation that funds veterinary care or your time as a volunteer on the ground.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/donate" class="bg-white text-primary font-bold px-10 py-4 rounded-full text-lg hover:brightness-95 transition inline-block">
          Donate Now
        </a>
        <a href="/get-involved" class="border-2 border-white text-white font-bold px-10 py-4 rounded-full text-lg hover:bg-white hover:text-primary transition inline-block">
          Volunteer
        </a>
      </div>
    </div>
  </section>

</Layout>
