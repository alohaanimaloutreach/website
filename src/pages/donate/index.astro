---
import Layout from '../../layouts/Layout.astro';
import DonationForm from '../../components/DonationForm.astro';
---

<Layout title="Donate | Aloha Animal Outreach" description="Your donation provides food, veterinary care, and rescue support to Honolulu's most vulnerable pets.">

  <!-- Hero -->
  <section class="relative py-12 md:py-16 overflow-hidden">
    <img src="/images/hero-donate.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-anchor/80"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold text-white leading-tight mb-6">
        Give a Pet the Care<br />They Deserve
      </h1>
      <p class="text-white/80 text-lg md:text-xl max-w-2xl mx-auto">
        100% of your donation goes directly to feeding, healing, and rehoming animals in need. We're volunteer-run, so every dollar works harder here.
      </p>
    </div>
  </section>

  <!-- Social Proof -->
  <div class="text-center py-6">
    <p class="text-text-muted text-base">
      Join our growing community of monthly donors supporting Oʻahu's most vulnerable pets.
    </p>
  </div>

  <!-- Donation Form + Photo -->
  <section class="py-8">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-8 items-start">
      <!-- Emotional Photo -->
      <div class="hidden md:block">
        <img
          src="/images/donate-hero.webp"
          alt="A volunteer caring for a dog during an Aloha Animal Outreach community visit"
          class="w-full h-full object-cover rounded-2xl"
          loading="eager"
        />
      </div>
      <!-- Form -->
      <div>
        <DonationForm />
      </div>
    </div>
  </section>

  <!-- Your Donation in Action -->
  <section class="py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h3 class="font-display text-2xl md:text-3xl font-bold text-text text-center mb-8">Your Donation in Action</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <p class="font-display text-3xl md:text-4xl font-bold text-primary mb-2">$15</p>
          <p class="text-text-muted text-sm leading-snug">A week of nutritious meals for one dog</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <p class="font-display text-3xl md:text-4xl font-bold text-primary mb-2">$30</p>
          <p class="text-text-muted text-sm leading-snug">A month of flea prevention for one dog</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <p class="font-display text-3xl md:text-4xl font-bold text-primary mb-2">$50</p>
          <p class="text-text-muted text-sm leading-snug">A wellness exam and vaccines</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <p class="font-display text-3xl md:text-4xl font-bold text-primary mb-2">$100</p>
          <p class="text-text-muted text-sm leading-snug">A spay or neuter surgery</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Donor Portal -->
  <section class="py-8">
    <div class="max-w-lg mx-auto px-4 text-center">
      <button id="portal-btn" class="inline-flex items-center gap-2 border border-primary text-primary font-semibold px-5 py-2.5 rounded-lg hover:bg-primary/5 transition text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Already a monthly donor? Manage your giving
      </button>
      <div id="portal-form" class="hidden mt-4">
        <input
          type="email"
          id="portal-email"
          placeholder="Enter your email"
          class="w-full px-4 py-3 border-2 border-bg rounded-lg focus:outline-none focus:border-primary transition mb-3"
        />
        <button id="portal-submit" class="bg-primary text-white font-semibold px-6 py-2 rounded-lg hover:brightness-110 transition">
          Open Donor Portal
        </button>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-8 text-center text-sm text-text-muted">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span>501(c)(3) Nonprofit</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          <span>Secure payments by Stripe</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <span>EIN: 87-1327369</span>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  const portalBtn = document.getElementById('portal-btn');
  const portalForm = document.getElementById('portal-form');
  const portalEmail = document.getElementById('portal-email') as HTMLInputElement;
  const portalSubmit = document.getElementById('portal-submit');

  portalBtn?.addEventListener('click', () => {
    portalForm?.classList.toggle('hidden');
  });

  portalSubmit?.addEventListener('click', async () => {
    const email = portalEmail?.value;
    if (!email) return;
    try {
      const res = await fetch('/api/donor-portal', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const json = await res.json();
      if (json.url) {
        window.location.href = json.url;
      }
    } catch {
      alert('Unable to open the donor portal. Please try again.');
    }
  });
</script>
