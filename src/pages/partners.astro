---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Partner With Us | Aloha Animal Outreach" description="Partner with Aloha Animal Outreach and put your support directly into the field — where it saves lives.">

  <!-- Hero -->
  <section class="relative pt-48 pb-24 md:pt-52 md:pb-32 overflow-hidden">
    <img src="/images/hero-home-2.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-anchor/80"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold text-white leading-tight mb-6">
        Make a Difference in Your Community
      </h1>
      <p class="text-white/80 text-lg md:text-xl max-w-2xl mx-auto">
        Partner with Aloha Animal Outreach and put your support directly into the field — where it saves lives.
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-4 text-text-muted leading-relaxed text-lg">
        <p>
          AAO runs entirely on the generosity of people and organizations who believe every animal deserves care, no matter where home is. We are 100% volunteer-run, which means every dollar from every partner goes directly to the animals and the people who love them.
        </p>
        <p>
          If your business or organization wants to make a real, visible impact on Oʻahu — on the street and in the community conversations that shape how houselessness is addressed — here is how we can work together.
        </p>
      </div>
    </div>
  </section>

  <!-- Partnership Options -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-center mb-12">Partnership Options</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <div class="bg-bg rounded-2xl p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-display text-xl font-semibold">Clinic Sponsor</h3>
            <span class="text-sm font-semibold text-primary bg-primary/10 px-3 py-1 rounded-full">$3,000 per clinic</span>
          </div>
          <p class="text-text-muted leading-relaxed">
            Sponsor a full spay/neuter clinic day. Your contribution funds surgeries for animals whose owners cannot afford care — and prevents dozens more animals from entering the cycle of houselessness. Named as presenting sponsor of the clinic. Recognized on our website, social media before and after the event, and in our field update to donors.
          </p>
        </div>

        <div class="bg-bg rounded-2xl p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-display text-xl font-semibold">Outreach Sponsor</h3>
            <span class="text-sm font-semibold text-primary bg-primary/10 px-3 py-1 rounded-full">Custom amount</span>
          </div>
          <p class="text-text-muted leading-relaxed">
            Fund one monthly outreach event — food, vaccines, flea and tick prevention, and supplies for every animal seen that day. A contained, tangible impact story your team can share. Named as outreach sponsor for that event. Recognized on social media and our website.
          </p>
        </div>

        <div class="bg-bg rounded-2xl p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-display text-xl font-semibold">Supply Partner</h3>
            <span class="text-sm font-semibold text-primary bg-primary/10 px-3 py-1 rounded-full">In-kind or cash</span>
          </div>
          <p class="text-text-muted leading-relaxed">
            Donate pet food, flea and tick preventatives, or veterinary supplies — either as a one-time contribution or an ongoing monthly partnership. Ideal for pet supply retailers, veterinary clinics, and pet food brands. Listed as an Official Supply Partner on our website.
          </p>
        </div>

        <div class="bg-bg rounded-2xl p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-display text-xl font-semibold">Workplace Giving</h3>
            <span class="text-sm font-semibold text-primary bg-primary/10 px-3 py-1 rounded-full">Any amount</span>
          </div>
          <p class="text-text-muted leading-relaxed">
            Run an internal fundraiser or set up a donation matching program for your employees. AAO provides an impact report and recognition package you can share with your team. Recognized as a Community Giving Partner.
          </p>
        </div>

        <div class="bg-bg rounded-2xl p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-display text-xl font-semibold">Advocacy Partner</h3>
            <span class="text-sm font-semibold text-primary bg-primary/10 px-3 py-1 rounded-full">Contact us</span>
          </div>
          <p class="text-text-muted leading-relaxed">
            Stand alongside AAO in the policy conversations happening right now about houselessness on Oʻahu. Our founder's connections to city officials and community organizations offer a rare opportunity for businesses and organizations that want to be part of systemic change — not just charitable giving. Co-recognition at advocacy events and in public communications.
          </p>
        </div>

        <div class="bg-bg rounded-2xl p-8">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-display text-xl font-semibold">Custom Partnership</h3>
            <span class="text-sm font-semibold text-primary bg-primary/10 px-3 py-1 rounded-full">Let's talk</span>
          </div>
          <p class="text-text-muted leading-relaxed">
            Have something else in mind? We are open to creative partnerships that serve the mission. Reach out and let us know what you are thinking.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- What Every Partner Receives -->
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-center mb-12">What Every Partnership Includes</h2>
      <div class="space-y-5">
        <div class="flex items-start gap-4">
          <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <p class="text-text-muted leading-relaxed">Recognition on the AAO website partners page</p>
        </div>
        <div class="flex items-start gap-4">
          <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <p class="text-text-muted leading-relaxed">Social media acknowledgment before, during, and after your contribution</p>
        </div>
        <div class="flex items-start gap-4">
          <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <p class="text-text-muted leading-relaxed">A field update with photos showing the impact of your partnership</p>
        </div>
        <div class="flex items-start gap-4">
          <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <p class="text-text-muted leading-relaxed">A tax deduction acknowledgment letter (AAO EIN: 87-1327369)</p>
        </div>
        <div class="flex items-start gap-4">
          <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <p class="text-text-muted leading-relaxed">The knowledge that your support goes 100% to the animals — no overhead, no staff salaries, no middlemen</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Inquiry Form -->
  <section class="py-20 bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-center mb-4">Start a Conversation</h2>
      <p class="text-text-muted text-center mb-12">Fill out the form below and we will be in touch within a few business days. There is no obligation — just a conversation about how we might work together.</p>

      <div class="bg-bg rounded-2xl shadow-sm border border-dark/10 p-8">
        <form id="partner-page-form" name="partner-inquiry-page" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="space-y-5">
          <input type="hidden" name="form-name" value="partner-inquiry-page" />
          <input type="hidden" name="Form" value="Partner Inquiry (Partners Page)" />
          <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="pp-org" class="block text-sm font-semibold mb-1">Organization Name</label>
              <input type="text" id="pp-org" name="organization" required
                class="w-full px-4 py-3 rounded-lg border border-dark/15 text-anchor bg-white placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary" />
            </div>
            <div>
              <label for="pp-contact" class="block text-sm font-semibold mb-1">Contact Name</label>
              <input type="text" id="pp-contact" name="contact-name" required
                class="w-full px-4 py-3 rounded-lg border border-dark/15 text-anchor bg-white placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="pp-email" class="block text-sm font-semibold mb-1">Email</label>
              <input type="email" id="pp-email" name="email" required
                class="w-full px-4 py-3 rounded-lg border border-dark/15 text-anchor bg-white placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary" />
            </div>
            <div>
              <label for="pp-phone" class="block text-sm font-semibold mb-1">Phone <span class="text-text-muted font-normal">(optional)</span></label>
              <input type="tel" id="pp-phone" name="phone"
                class="w-full px-4 py-3 rounded-lg border border-dark/15 text-anchor bg-white placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary" />
            </div>
          </div>

          <div>
            <label for="pp-interest" class="block text-sm font-semibold mb-1">Partnership interest</label>
            <select id="pp-interest" name="partnership-type" required
              class="w-full px-4 py-3 rounded-lg border border-dark/15 text-anchor bg-white focus:outline-none focus:ring-2 focus:ring-primary">
              <option value="" disabled selected>Select one</option>
              <option value="clinic-sponsor">Clinic Sponsor ($3,000)</option>
              <option value="outreach-sponsor">Outreach Sponsor</option>
              <option value="supply-partner">Supply Partner</option>
              <option value="workplace-giving">Workplace Giving</option>
              <option value="advocacy-partner">Advocacy Partner</option>
              <option value="custom">Custom / Other</option>
            </select>
          </div>

          <div>
            <label for="pp-about" class="block text-sm font-semibold mb-1">Tell us about your organization and how you would like to help <span class="text-text-muted font-normal">(optional)</span></label>
            <textarea id="pp-about" name="about" rows="4"
              class="w-full px-4 py-3 rounded-lg border border-dark/15 text-anchor bg-white placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary resize-y"></textarea>
          </div>

          <button type="submit"
            class="bg-primary text-white font-bold px-8 py-3 rounded-full hover:brightness-110 transition">
            Send Inquiry
          </button>
        </form>
        <p id="partner-page-msg" class="mt-4 text-primary font-semibold hidden"></p>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-primary py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-6">Not Ready to Partner Yet?</h2>
      <p class="text-white/90 text-lg mb-10">A monthly donation of any size makes a direct impact. Every dollar goes to the animals.</p>
      <a href="/donate" class="bg-white text-primary font-bold px-10 py-4 rounded-full text-lg hover:brightness-95 transition inline-block">
        Donate Now
      </a>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('partner-page-form') as HTMLFormElement;
  const msg = document.getElementById('partner-page-msg');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    try {
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data as any).toString(),
      });
      if (msg) {
        msg.classList.remove('hidden');
        msg.textContent = 'Thank you — we will be in touch soon. Mahalo for your support.';
      }
      form.reset();
    } catch {
      if (msg) {
        msg.classList.remove('hidden');
        msg.classList.add('text-alert');
        msg.textContent = 'Something went wrong. Please try again.';
      }
    }
  });
</script>
