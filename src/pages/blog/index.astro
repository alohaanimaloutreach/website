---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
function formatDate(date: Date): string {
  return `${monthNames[date.getMonth()]} ${date.getDate()}, ${date.getFullYear()}`;
}
---

<Layout title="Blog | Aloha Animal Outreach" description="Stories from the field, outreach recaps, and updates from Aloha Animal Outreach.">

  <!-- Hero -->
  <section class="relative pt-40 pb-24 md:pt-48 md:pb-32 overflow-hidden">
    <img src="/images/hero-involved.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-anchor/80"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold text-white leading-tight mb-6">
        From the Field
      </h1>
      <p class="text-white/80 text-lg md:text-xl max-w-2xl mx-auto">
        Stories, recaps, and updates from our work on Oʻahu.
      </p>
    </div>
  </section>

  <!-- Blog Posts -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length === 0 ? (
        <p class="text-center text-text-muted text-lg">No posts yet — check back soon!</p>
      ) : (
        <div class="space-y-10">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="block group">
              <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                {post.data.image && (
                  <div class="overflow-hidden">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      class="w-full h-64 object-cover group-hover:scale-[1.02] transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-8">
                  <div class="flex items-center gap-3 text-sm text-text-muted mb-3">
                    <time datetime={post.data.date.toISOString().split('T')[0]}>
                      {formatDate(post.data.date)}
                    </time>
                    {post.data.tags.length > 0 && (
                      <>
                        <span>·</span>
                        <span>{post.data.author}</span>
                      </>
                    )}
                  </div>
                  <h2 class="font-display text-2xl md:text-3xl font-bold mb-3 group-hover:text-primary transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="text-text-muted leading-relaxed">{post.data.description}</p>
                  <span class="inline-block mt-4 text-primary font-semibold text-sm">
                    Read more →
                  </span>
                </div>
              </article>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

</Layout>
